{
  "extends": [
    "config:base",
    ":disableDependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(fix)"
  ],
  "labels": [
    "dependencies"
  ],
  "commitBody": "[skip ci]",
  "packageRules": [
    {
      "automerge": false,
      "description": "No Automerge all updates except major versions",
      "matchUpdateTypes": [
        "patch",
        "pin",
        "digest",
        "minor"
      ]
    },
    {
      "automerge": false,
      "description": "Group minor and patch updates into a single PR",
      "groupName": "dependencies",
      "managers": [
        "nuget",
        "dockerfile",
        "docker-compose",
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    }
  ],
  "autoApprove": true,
  "prConcurrentLimit": 2,
  "separateMinorPatch": true,
  "timezone": "Europe/Berlin"
}
